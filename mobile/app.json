{
  "expo": {
    "name": "TMS Driver",
    "slug": "tms-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "tms-driver",
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Cần GPS để ghi nhận vị trí chốt chặng"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Cần camera để chụp ảnh chốt chặng",
        "NSPhotoLibraryUsageDescription": "Cần thư viện ảnh để chọn ảnh",
        "NSLocationWhenInUseUsageDescription": "Cần GPS để ghi nhận vị trí chốt chặng",
        "UIDesignRequiresCompatibility": true,
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      },
      "bundleIdentifier": "com.anonymous.tmsmobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.tmsmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
