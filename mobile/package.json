{
  "name": "tms-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "expo": "~57.0.2",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.0",
    "expo-router": "~5.0.5",
    "expo-status-bar": "~57.0.0",
    "leaflet": "^1.9.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "~4.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "sed -i \"s|baseUrl = process.env.EXPO_BASE_URL|baseUrl = '/mobile'|g\" node_modules/expo-router/build/fork/getPathFromState.js node_modules/expo-router/build/fork/getPathFromState-forks.js node_modules/expo-router/build/fork/getStateFromPath-forks.js",
    "build:web": "rm -rf ../public/mobile && npx expo export --platform web --output-dir ../public/mobile && sed -i 's|href=\"/favicon.ico\"|href=\"/mobile/favicon.ico\"|' ../public/mobile/index.html && sed -i 's|href=\"/_expo/|href=\"/mobile/_expo/|g' ../public/mobile/index.html && sed -i 's|src=\"/_expo/|src=\"/mobile/_expo/|' ../public/mobile/index.html && sed -i 's|\"/assets/|\"/mobile/assets/|g' ../public/mobile/_expo/static/js/web/entry-*.js"
  },
  "private": true
}
